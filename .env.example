# Required environment variables — copy to .env and fill in values
# NEVER commit .env to git

# === Domain ===
DOMAIN=radio.yourdomain.com

# === Icecast2 ===
ICECAST_SOURCE_PASSWORD=changeme_source
ICECAST_RELAY_PASSWORD=changeme_relay
ICECAST_ADMIN_PASSWORD=changeme_admin
ICECAST_ADMIN_USER=admin
ICECAST_HOSTNAME=localhost
ICECAST_PORT=8000
ICECAST_MAX_LISTENERS=100

# === Station Info ===
STATION_NAME=My VPS Radio
STATION_DESCRIPTION=Live internet radio
STATION_GENRE=Various
STATION_URL=https://radio.yourdomain.com

# === Cloudflare R2 (podcast archive) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vps-radio-archive
R2_PUBLIC_URL=

# === Telegram Alerts ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === API ===
API_SECRET=changeme_api_secret
ADMIN_PASSWORD=changeme_admin_password
API_PORT=4000
NODE_ENV=production
